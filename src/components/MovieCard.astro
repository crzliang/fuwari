---
import { Icon } from "astro-icon/components";
import ImageWrapper from "./misc/ImageWrapper.astro";

interface MovieData {
	title: string;
	originalTitle?: string;
	year: number;
	watchedDate: Date;
	rating: number;
	poster?: string;
	genres?: string[];
	country?: string;
	director?: string;
	status: "watched" | "rewatched" | "watchlist";
	tags?: string[];
}

interface Props {
	movie: {
		data: MovieData;
	};
}

const { movie } = Astro.props;
const {
	title,
	originalTitle,
	year,
	watchedDate,
	rating,
	poster,
	genres = [],
	country,
	director,
	status,
	tags = [],
} = movie.data;

const watchedDateText = watchedDate.toLocaleDateString("zh-CN", {
	year: "numeric",
	month: "2-digit",
	day: "2-digit",
});

const ratingText = Number.isInteger(rating) ? `${rating}.0` : rating.toFixed(1);

const statusLabelMap: Record<MovieData["status"], string> = {
	watched: "已看",
	rewatched: "二刷",
	watchlist: "想看",
};

const statusLabel = statusLabelMap[status];
const metaItems = [country, director].filter((item): item is string => Boolean(item));
---

<article class="card-base group overflow-hidden rounded-[var(--radius-large)] h-full flex flex-col">
	<div class="grid md:grid-cols-[11rem_1fr] h-full">
		<div class="relative min-h-[16rem] md:min-h-full bg-black/5 dark:bg-white/5">
			{poster ? (
				<ImageWrapper src={poster} basePath="content/movies/" alt={`${title} 海报`} class="h-full w-full" />
			) : (
				<div class="h-full w-full flex items-center justify-center text-black/30 dark:text-white/30">
					<Icon name="material-symbols:movie-outline-rounded" class="text-6xl" />
				</div>
			)}
			<div class="absolute inset-x-0 top-0 flex items-start p-3 pointer-events-none">
				<span class="rounded-full bg-black/55 text-white text-xs px-2.5 py-1 backdrop-blur-sm">
					{statusLabel}
				</span>
			</div>
		</div>

		<div class="p-5 md:p-6 flex flex-col gap-4">
			<div class="flex items-start justify-between gap-4">
				<div>
					<h2 class="text-2xl font-bold text-90 leading-tight">{title}</h2>
					{originalTitle && (
						<p class="text-sm mt-1 text-black/55 dark:text-white/55">{originalTitle}</p>
					)}
				</div>
				<div class="shrink-0 text-right">
					<div class="text-xs uppercase tracking-[0.2em] text-black/40 dark:text-white/40">豆瓣评分</div>
					<div class="text-2xl font-bold text-[var(--primary)]">{ratingText}</div>
				</div>
			</div>

			<div class="flex flex-wrap gap-2 text-sm text-black/65 dark:text-white/65">
				<span class="rounded-full bg-black/5 dark:bg-white/10 px-3 py-1">{year}</span>
				<span class="rounded-full bg-black/5 dark:bg-white/10 px-3 py-1">观看于 {watchedDateText}</span>
				{metaItems.map((item) => (
					<span class="rounded-full bg-black/5 dark:bg-white/10 px-3 py-1">{item}</span>
				))}
			</div>

			{genres.length > 0 && (
				<div class="flex flex-wrap gap-2">
					{genres.map((genre: string) => (
						<span class="text-xs rounded-full px-2.5 py-1 bg-[var(--btn-regular-bg)] text-black/70 dark:text-white/70">
							{genre}
						</span>
					))}
				</div>
			)}

			{tags.length > 0 && (
				<div class="mt-auto flex flex-wrap gap-2 pt-2">
					{tags.map((tag: string) => (
						<span class="text-xs rounded-full px-2.5 py-1 border border-black/10 dark:border-white/10 text-black/55 dark:text-white/55">
							#{tag}
						</span>
					))}
				</div>
			)}
		</div>
	</div>
</article>
